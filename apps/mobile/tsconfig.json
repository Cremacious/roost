{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@roost/constants": [
        "../../packages/constants/src/index.ts"
      ],
      "@roost/constants/*": [
        "../../packages/constants/src/*"
      ],
      "@roost/api-types": [
        "../../packages/api-types/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
